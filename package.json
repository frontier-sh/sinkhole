{
  "name": "sinkhole-worker",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run build && wrangler dev",
    "build": "vite build && vite build --mode client && cp -r public/* dist/assets/ 2>/dev/null || true",
    "deploy": "wrangler d1 migrations apply sinkhole-db --remote && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply sinkhole-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply sinkhole-db --remote"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "partyserver": "^0.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@tailwindcss/vite": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.64.0"
  }
}
